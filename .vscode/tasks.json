{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build (SDCC)",
      "type": "shell",
      "command": "powershell -ExecutionPolicy Bypass -File ./scripts_build.ps1",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": []
    },
    {
      "label": "Flash (ST-Link)",
      "type": "shell",
      "command": "powershell -ExecutionPolicy Bypass -File ./scripts_flash.ps1",
      "problemMatcher": []
    },
    {
      "label": "Build + Flash",
      "dependsOn": ["Build (SDCC)", "Flash (ST-Link)"],
      "dependsOrder": "sequence",
      "problemMatcher": []
    },
    {
      "label": "Clean",
      "type": "shell",
      "command": "powershell -ExecutionPolicy Bypass -Command \"if(Test-Path build){Remove-Item -Recurse -Force build/*}\"",
      "problemMatcher": []
    }
  ]
}
